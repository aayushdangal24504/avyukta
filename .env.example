# ============================================================
#  AVYUKTA — environment variables (copy to .env.local for local dev)
# ============================================================
#
#  These two are baked into the BROWSER bundle at build time (Vite inlines
#  VITE_* values). That is expected and fine: the Supabase ANON key is a
#  PUBLIC key by design. Security does NOT come from hiding it — it comes
#  from Row-Level Security policies inside Supabase.
#
#  Set these in your host's environment (Vercel → Settings → Environment
#  Variables; Netlify → Site settings → Environment variables), then rebuild.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=paste_your_anon_PUBLIC_key_here


# ============================================================
#  ⛔  NEVER add the following to this file or to VITE_* — they are
#      SERVER-ONLY secrets. If any of these ever reach the browser or a
#      public repo, your database can be fully taken over.
#
#      These are set as Supabase Edge Function secrets (Dashboard →
#      Edge Functions → Secrets, or `supabase secrets set ...`):
#
#        SUPABASE_SERVICE_ROLE_KEY = ...   (full DB access — server only)
#        RESEND_API_KEY            = ...   (email provider — server only)
#        EMAIL_FROM                = "Your Store <orders@yourdomain.com>"
# ============================================================
